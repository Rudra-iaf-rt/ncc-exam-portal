// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// STUDENT: regimentalNumber required; ADMIN/INSTRUCTOR: email required (login paths differ)
model User {
  id                 Int       @id @default(autoincrement())
  name               String
  regimentalNumber   String?   @unique
  email              String?   @unique
  mobile             String?
  batch              String?   // e.g., 2024-25
  yearOfStudy        String?
  password           String
  role               String    // STUDENT | ADMIN | INSTRUCTOR
  college            String
  wing               String?   // ARMY | NAVY | AIR
  isActive           Boolean   @default(true)
  refreshToken       String?   // Legacy refresh token field from staging
  
  examsCreated       Exam[]    @relation("ExamCreator")
  attempts           Attempt[]
  results            Result[]
  materialsUploaded  Material[]
  passwordResetTokens PasswordResetToken[]
  sentNotifications  Notification[] @relation("NotificationSender")
  receivedNotifications Notification[] @relation("NotificationRecipient")
  examViolations     ExamViolation[]
  examHeartbeats     ExamHeartbeat[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]  // Detailed refresh tokens from HEAD
  assignments        ExamAssignment[]
}



model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Material {
  id           Int      @id @default(autoincrement())
  title        String?
  category     String?  // From staging
  originalName String
  storedName   String   @unique
  mimeType     String
  sizeBytes    Int
  fileUrl      String?  // From staging
  examId       Int?     // From staging
  uploadedById Int
  
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  exam         Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model Exam {
  id          Int              @id @default(autoincrement())
  title       String
  duration    Int // minutes
  status      String           @default("DRAFT") // DRAFT | LIVE | ARCHIVED
  publishedAt DateTime?
  createdBy   Int
  createdAt   DateTime         @default(now())
  creator     User             @relation("ExamCreator", fields: [createdBy], references: [id])
  questions   Question[]
  attempts    Attempt[]
  results     Result[]
  assignments ExamAssignment[]
  materials   Material[]
  violations  ExamViolation[]
  heartbeats  ExamHeartbeat[]
}

model ExamAssignment {
  id        Int      @id @default(autoincrement())
  userId    Int
  examId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
}

model Question {
  id       Int      @id @default(autoincrement())
  examId   Int
  question String
  options  String[]
  answer   String
  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model Attempt {
  id           Int       @id @default(autoincrement())
  studentId    Int
  examId       Int
  status       String    // IN_PROGRESS | SUBMITTED | TIMED_OUT
  answers      Json?     @default("[]")
  currentQuestionIndex Int @default(0)
  warningCount Int       @default(0)     // Server-side proctoring violation counter
  startedAt    DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  
  student      User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam         Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}

model Result {
  id        Int      @id @default(autoincrement())
  studentId Int
  examId    Int
  score     Int // percentage 0–100
  createdAt DateTime @default(now())
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}

model ExamViolation {
  id        Int      @id @default(autoincrement())
  studentId Int
  examId    Int
  type      String
  message   String?
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([studentId, examId])
  @@index([examId, createdAt])
}

model ExamHeartbeat {
  id                  Int      @id @default(autoincrement())
  studentId           Int
  examId              Int
  activeQuestionIndex Int?
  lastSeenAt          DateTime @updatedAt
  createdAt           DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
  @@index([examId, lastSeenAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  userId    Int?
  sentById  Int
  createdAt DateTime @default(now())

  recipient User? @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: SetNull)
  sender    User  @relation("NotificationSender", fields: [sentById], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sentById, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  entityType String?
  entityId   String?
  method     String
  path       String
  statusCode Int
  ip         String?
  userAgent  String?
  requestId  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  userId     Int
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}