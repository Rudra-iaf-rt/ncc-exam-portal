// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// STUDENT: regimentalNumber required; ADMIN/INSTRUCTOR: email required (login paths differ)
model User {
  id               Int       @id @default(autoincrement())
  name             String
  regimentalNumber String?   @unique
  email            String?   @unique
  mobile           String?
  batch            String?
  yearOfStudy      String?
  password         String
  role             String // STUDENT | ADMIN | INSTRUCTOR
  college          String
  examsCreated     Exam[]    @relation("ExamCreator")
  attempts         Attempt[]
  results          Result[]
  materialsUploaded Material[]
}

model Material {
  id             Int      @id @default(autoincrement())
  title          String?
  originalName   String
  storedName     String   @unique
  mimeType       String
  sizeBytes      Int
  uploadedById   Int
  uploadedBy     User     @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime @default(now())
}

model Exam {
  id        Int        @id @default(autoincrement())
  title     String
  duration  Int // minutes
  createdBy Int
  createdAt DateTime   @default(now())
  creator   User       @relation("ExamCreator", fields: [createdBy], references: [id])
  questions Question[]
  attempts  Attempt[]
  results   Result[]
}

model Question {
  id       Int      @id @default(autoincrement())
  examId   Int
  question String
  options  String[]
  answer   String
  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model Attempt {
  id        Int      @id @default(autoincrement())
  studentId Int
  examId    Int
  status    String // IN_PROGRESS | SUBMITTED
  createdAt DateTime @default(now())
  student   User     @relation(fields: [studentId], references: [id])
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}

model Result {
  id        Int      @id @default(autoincrement())
  studentId Int
  examId    Int
  score     Int // percentage 0–100
  createdAt DateTime @default(now())
  student   User     @relation(fields: [studentId], references: [id])
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}
