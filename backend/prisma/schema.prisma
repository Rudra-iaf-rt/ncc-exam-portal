generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                  @id @default(autoincrement())
  name                  String
  regimentalNumber      String?              @unique
  email                 String?              @unique
  password              String
  role                  String
  refreshToken          String?
  batch                 String?
  isActive              Boolean              @default(true)
  wing                  String?
  mobile                String?
  yearOfStudy           String?
  collegeCode           String?
  attempts              Attempt[]
  auditLogs             AuditLog[]
  examsCreated          Exam[]               @relation("ExamCreator")
  assignments           ExamAssignment[]
  examHeartbeats        ExamHeartbeat[]
  examViolations        ExamViolation[]
  materialsUploaded     Material[]
  sentNotifications     Notification[]       @relation("NotificationSender")
  receivedNotifications Notification[]       @relation("NotificationRecipient")
  passwordResetTokens   PasswordResetToken[]
  refreshTokens         RefreshToken[]
  results               Result[]
  college               College?             @relation(fields: [collegeCode], references: [code])
}

model College {
  id              Int        @id @default(autoincrement())
  name            String     @unique
  code            String     @unique
  address         String?
  city            String?
  state           String?
  pincode         String?
  nccContactName  String?
  nccContactEmail String?
  nccContactPhone String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  materials       Material[]
  users           User[]

  @@index([isActive])
  @@index([code])
}

model Batch {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Material {
  id           Int          @id @default(autoincrement())
  title        String?
  category     String?
  fileUrl      String?
  examId       Int?
  createdAt    DateTime     @default(now())
  mimeType     String?
  originalName String?
  sizeBytes    Int?
  storedName   String?      @unique
  uploadedById Int
  accessStatus AccessStatus @default(VERIFIED)
  collegeId    Int?
  description  String?
  driveFileId  String?
  fileType     FileType?
  isActive     Boolean      @default(true)
  subject      String?
  updatedAt    DateTime     @updatedAt
  wing         String?
  college      College?     @relation(fields: [collegeId], references: [id])
  exam         Exam?        @relation(fields: [examId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
}

model Exam {
  id          Int              @id @default(autoincrement())
  title       String
  duration    Int
  createdBy   Int
  createdAt   DateTime         @default(now())
  status      String           @default("DRAFT")
  publishedAt DateTime?
  attempts    Attempt[]
  creator     User             @relation("ExamCreator", fields: [createdBy], references: [id])
  assignments ExamAssignment[]
  heartbeats  ExamHeartbeat[]
  violations  ExamViolation[]
  materials   Material[]
  questions   Question[]
  results     Result[]
}

model ExamAssignment {
  id        Int      @id @default(autoincrement())
  userId    Int
  examId    Int
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
}

model Question {
  id       Int      @id @default(autoincrement())
  examId   Int
  question String
  options  String[]
  answer   String
  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model Attempt {
  id                   Int      @id @default(autoincrement())
  studentId            Int
  examId               Int
  status               String
  createdAt            DateTime @default(now())
  answers              Json?    @default("[]")
  startedAt            DateTime @default(now())
  warningCount         Int      @default(0)
  currentQuestionIndex Int      @default(0)
  updatedAt            DateTime @default(now()) @updatedAt
  exam                 Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student              User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}

model Result {
  id        Int      @id @default(autoincrement())
  studentId Int
  examId    Int
  score     Int
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}

model ExamViolation {
  id        Int      @id @default(autoincrement())
  studentId Int
  examId    Int
  type      String
  message   String?
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, examId])
  @@index([examId, createdAt])
}

model ExamHeartbeat {
  id                  Int      @id @default(autoincrement())
  studentId           Int
  examId              Int
  activeQuestionIndex Int?
  lastSeenAt          DateTime @updatedAt
  createdAt           DateTime @default(now())
  exam                Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student             User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
  @@index([examId, lastSeenAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  userId    Int?
  sentById  Int
  createdAt DateTime @default(now())
  sender    User     @relation("NotificationSender", fields: [sentById], references: [id], onDelete: Cascade)
  recipient User?    @relation("NotificationRecipient", fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sentById, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  entityType String?
  entityId   String?
  method     String
  path       String
  statusCode Int
  ip         String?
  userAgent  String?
  requestId  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

enum FileType {
  PDF
  VIDEO
  DOCUMENT
}

enum AccessStatus {
  VERIFIED
  RESTRICTED
  PENDING
  ERROR
}
