# PostgreSQL connection (Prisma 7 + adapter-pg)
# Replace user, password, host, port, and database name.
DATABASE_URL="postgresql://postgres:rudra2006@localhost:5432/ncc_db"

# Required for JWT auth (use a long random string in production)
JWT_SECRET="rudra2006"

# Optional token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# API server port (optional)
# PORT=3000

# Password reset (email)
# For Gmail, generate an App Password and set SMTP_USER + SMTP_PASS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your_app_password"
# SMTP_FROM="NCC Exam Portal <your@gmail.com>"
#
# Used to build the reset link (HTTPS web URL or Expo deep-link scheme).
# Must match `scheme` in the mobile app `app.json` (e.g. ncc-exam).
# APP_RESET_URL_BASE="ncc-exam://"
#
# Token expiry window (minutes)
# PASSWORD_RESET_TTL_MINUTES=30

# Exam import from PDF (optional — enables AI extraction of MCQs from PDF text)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
